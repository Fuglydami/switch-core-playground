{
  "typography": {
    "fontFamily": {
      "sans": { "$value": "'Averta', system-ui, sans-serif", "$type": "fontFamily", "$description": "Primary font — Averta" },
      "mono": { "$value": "'JetBrains Mono', monospace",    "$type": "fontFamily" }
    },
    "fontWeight": {
      "thin":      { "$value": 100, "$type": "fontWeight" },
      "light":     { "$value": 300, "$type": "fontWeight" },
      "regular":   { "$value": 400, "$type": "fontWeight" },
      "semibold":  { "$value": 600, "$type": "fontWeight" },
      "bold":      { "$value": 700, "$type": "fontWeight" },
      "extraBold": { "$value": 800, "$type": "fontWeight" },
      "black":     { "$value": 900, "$type": "fontWeight" }
    },
    "fontSize": {
      "body": {
        "small":    { "$value": "12px", "$type": "dimension", "$description": "Body Small" },
        "medium":   { "$value": "14px", "$type": "dimension", "$description": "Body Medium" },
        "subtitle": { "$value": "20px", "$type": "dimension", "$description": "Body Subtitle" }
      },
      "header": {
        "h1": { "$value": "72px", "$type": "dimension" },
        "h2": { "$value": "56px", "$type": "dimension" },
        "h3": { "$value": "40px", "$type": "dimension" },
        "h4": { "$value": "32px", "$type": "dimension" },
        "h5": { "$value": "28px", "$type": "dimension" },
        "h6": { "$value": "20px", "$type": "dimension" },
        "h7": { "$value": "16px", "$type": "dimension" },
        "h8": { "$value": "14px", "$type": "dimension" },
        "h9": { "$value": "12px", "$type": "dimension" }
      },
      "display": {
        "d1": { "$value": "48px", "$type": "dimension" },
        "d2": { "$value": "64px", "$type": "dimension" },
        "d3": { "$value": "96px", "$type": "dimension" }
      }
    },
    "lineHeight": {
      "tight":   { "$value": 1.2,  "$type": "number" },
      "snug":    { "$value": 1.375,"$type": "number" },
      "normal":  { "$value": 1.5,  "$type": "number" },
      "relaxed": { "$value": 1.625,"$type": "number" }
    }
  }
}
