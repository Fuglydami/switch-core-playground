    "react-native-svg": { "optional": true }
  },
  "devDependencies": {
    "@switch/tsconfig": "workspace:*",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@types/node": "^22.0.0",
    "svgo": "^3.3.0",
    "typescript": "^5.0.0"
  }
